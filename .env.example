# Anthropic API Key (required for AI Medical Analysis)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App access passphrase (required — protects all health data)
# Set this to a strong passphrase that authorized users will enter on the login screen
APP_PASSPHRASE=your_secure_passphrase_here

# Vercel Blob Storage Token (required for file uploads)
# Created automatically when you add Blob storage in your Vercel project dashboard
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
