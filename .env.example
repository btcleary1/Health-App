# Auth feature flag — set to "true" to enforce Clerk login, omit or set to anything else to bypass
AUTH_ENABLED=false

# Clerk Authentication (required when AUTH_ENABLED=true)
# Sign up at clerk.com → create app → copy keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Anthropic API Key (required for AI Medical Analysis)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel Blob Storage Token (required for file uploads)
# Created automatically when you add Blob storage in your Vercel project dashboard
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
